@using FlightReservationApp_f.Models
@model IEnumerable<FlightReservationApp_f.Models.Flight>

<div class="d-flex justify-content-between mb-3">
    <!-- Login and SignUp buttons -->
    <div>
        <a asp-action="Login" asp-controller="User" class="btn btn-outline-primary me-2">Login</a>
        <a asp-action="SignUp" asp-controller="User" class="btn btn-primary">SignUp</a>
    </div>

    <!-- Search form -->
    <form method="get" class="form-inline">
        <div class="form-group">
            <label for="flightNumberSearch" class="sr-only">Search by Flight Number</label>
            <input type="text" id="flightNumberSearch" name="flightNumberSearch" class="form-control" placeholder="Enter flight number" value="@Context.Request.Query["flightNumberSearch"]" />
        </div>
        <button type="submit" class="btn btn-primary ml-2">Search</button>
    </form>
</div>

<p>
    <a asp-action="Create" class="btn btn-success">Create New Flight</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>
                <a href="@Url.Action("Index", new { sortOrder = ViewData["FlightNumberSortParm"], flightNumberSearch = Context.Request.Query["flightNumberSearch"].ToString() })">Flight Number</a>
            </th>
            <th>
                <a href="@Url.Action("Index", new { sortOrder = ViewData["OriginSortParm"], flightNumberSearch = Context.Request.Query["flightNumberSearch"].ToString() })">Origin</a>
            </th>
            <th>
                <a href="@Url.Action("Index", new { sortOrder = ViewData["DestinationSortParm"], flightNumberSearch = Context.Request.Query["flightNumberSearch"].ToString() })">Destination</a>
            </th>
            <th>
                <a href="@Url.Action("Index", new { sortOrder = ViewData["DepartureTimeSortParm"], flightNumberSearch = Context.Request.Query["flightNumberSearch"].ToString() })">Departure Time</a>
            </th>
            <th>
                <a href="@Url.Action("Index", new { sortOrder = ViewData["ArrivalTimeSortParm"], flightNumberSearch = Context.Request.Query["flightNumberSearch"].ToString() })">Arrival Time</a>
            </th>
            <th>
                <a href="@Url.Action("Index", new { sortOrder = ViewData["PriceSortParm"], flightNumberSearch = Context.Request.Query["flightNumberSearch"].ToString() })">Price</a>
            </th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var flight in Model)
        {
            <tr>
                <td>@flight.FlightNumber</td>
                <td>@flight.Origin</td>
                <td>@flight.Destination</td>
                <td>@flight.DepartureTime</td>
                <td>@flight.ArrivalTime</td>
                <td>@flight.Price.ToString("C")</td>
                <td>
                    <a href="@Url.Action("Details", "Flights", new { id = flight.Id })" class="btn btn-info btn-sm">Details</a>
                    <a href="@Url.Action("Edit", "Flights", new { id = flight.Id })" class="btn btn-warning btn-sm">Edit</a>
                    <a href="@Url.Action("Delete", "Flights", new { id = flight.Id })" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
