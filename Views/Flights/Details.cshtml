@using FlightReservationApp_f.Models
@model FlightReservationApp_f.Models.Flight

@{
    ViewData["Title"] = "Flight Details";
}

<h1>Flight Details</h1>

<div>
    <h4>Flight</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.FlightNumber)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.FlightNumber)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Type)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Type)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Origin)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Origin)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Destination)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Destination)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.DepartureTime)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.DepartureTime)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ArrivalTime)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ArrivalTime)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.DepartureLocation)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.DepartureLocation)
        </dd>
        <!-- Price field formatted as currency -->
        <dt class="col-sm-2">Price</dt>
        <dd class="col-sm-10">@Model.Price.ToString("C")</dd>
    </dl>
</div>

<!-- Passengers Section -->
<div>
    <h3>Passengers on this Flight</h3>

    @if (Model.FlightPassengers != null && Model.FlightPassengers.Any())
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Passenger Name</th>
                    <th>Email</th>
                    <th>Contact Number</th>
                    <th>Flight Cost</th> <!-- Added column for Flight Cost -->
                </tr>
            </thead>
            <tbody>
                @foreach (var flightPassenger in Model.FlightPassengers)
                {
                    <tr>
                        <td>@flightPassenger.Passenger.FullName</td>
                        <td>@flightPassenger.Passenger.Email</td>
                        <td>@flightPassenger.Passenger.ContactNumber</td>
                        <td>@Model.Price.ToString("C")</td> <!-- Display flight cost for each passenger -->
                    </tr>
                }
            </tbody>
        </table>

        <!-- Total Price -->
        <div>
            <strong>Total Price for All Passengers: </strong>
            @{
                var totalPrice = Model.FlightPassengers.Count() * Model.Price;
            }
            <span>@totalPrice.ToString("C")</span>
        </div>
    }
    else
    {
        <p>No passengers are currently booked on this flight.</p>
    }
</div>

<!-- Edit, Delete, and Back to List buttons -->
<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-primary">Edit</a> |
    <a asp-action="Delete" asp-route-id="@Model?.Id" class="btn btn-danger">Delete</a> |
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>
